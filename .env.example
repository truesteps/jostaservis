# Copy to .env for local dev (with `netlify dev`); set the same keys in the
# Netlify UI (Site config → Environment variables) for production.
# .env is gitignored — never commit real keys.

# --- Contact form: e-mail delivery (Resend) — read at runtime by the function ---
# Resend API key (https://resend.com → API Keys). Starts with "re_".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Where inquiries are sent. Comma-separate for several recipients.
CONTACT_TO=Stasek.Josef@email.cz
# Optional. Sender address on a Resend-verified domain.
# Defaults to "JOSTA web <poptavka@jostaservis.cz>" if unset.
# Verify jostaservis.cz in Resend before going live.
CONTACT_FROM=JOSTA web <poptavka@jostaservis.cz>

# --- Contact form: bot protection (Cloudflare Turnstile) — optional ---
# Leave both blank to disable Turnstile (form still works via the other layers).
# Cloudflare dashboard → Turnstile → add a site → copy the two keys.
# PUBLIC site key — inlined into the client at BUILD time (must be set for the build).
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA_your_site_key
# SECRET key — read at runtime by the function. Never expose this to the client.
TURNSTILE_SECRET_KEY=0x4AAAAAAA_your_secret_key
